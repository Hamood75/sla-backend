DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,api.streetlabsafrica.org
CORS_ALLOWED_ORIGINS=https://streetlabsafrica.org,https://www.streetlabsafrica.org,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173
PUBLIC_SITE_URL=https://streetlabsafrica.org
# QR images always encode PUBLIC_SITE_URL (never FRONTEND_URL).
# Only set this on purpose for local QR testing:
# QR_PUBLIC_BASE_URL=http://localhost:5173
# SQLite (local dev)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL (Docker)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=sla_db
# DB_USER=sla_user
# DB_PASSWORD=sla_pass
# DB_HOST=db
# DB_PORT=5432

# Contact / meeting emails (SMTP)
# Local default logs to console. Production / Docker must use SMTP + password.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=nxmail.nexacon.africa
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=noreply@streetlabsafrica.org
# EMAIL_HOST_PASSWORD=your-smtp-password
# DEFAULT_FROM_EMAIL=noreply@streetlabsafrica.org
# Optional extra alert recipients (comma-separated), in addition to CMS Settings email:
# CONTACT_NOTIFY_EMAIL=you@example.com

# Max request body for hero video / media uploads (bytes). Also raise nginx client_max_body_size to 600M.
# DATA_UPLOAD_MAX_MEMORY_SIZE=629145600
# FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
